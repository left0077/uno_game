{
  "name": "uno-e2e",
  "version": "2.0.0",
  "description": "Uno Online E2E Tests - Playwright",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:local": "playwright test --config=playwright.config.local.ts",
    "test:local:headed": "playwright test --config=playwright.config.local.ts --headed",
    "test:local:ui": "playwright test --config=playwright.config.local.ts --ui",
    "test:basic": "playwright test core-features/basic.spec.ts",
    "test:gameplay": "playwright test core-features/gameplay.spec.ts",
    "test:core": "playwright test core-features/",
    "test:modes": "playwright test game-modes/",
    "test:regression": "playwright test regression/",
    "report": "playwright show-report",
    "report:local": "playwright show-report playwright-report-local",
    "clean": "rm -rf test-results playwright-report playwright-report-local"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
