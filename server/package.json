{
  "name": "uno-server",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "test": "tsx src/test/index.ts",
    "test:action-api": "tsx src/test/run-action-api-tests.ts",
    "test:base": "tsx src/test/action-api/base.test.ts",
    "test:out": "tsx src/test/action-api/out-mode.test.ts",
    "test:penalty": "tsx src/test/action-api/penalty-response.test.ts",
    "test:combo": "tsx src/test/action-api/combo-response.test.ts",
    "test:integration": "tsx src/test/integration/action-api-integration.test.ts",
    "test:performance": "tsx src/test/performance/action-api-performance.test.ts"
  },
  "dependencies": {
    "express": "^4.18.3",
    "socket.io": "^4.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.11.24",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
